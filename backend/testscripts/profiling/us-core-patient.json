    "setup": {
        "action": [
            {
                "operation": {
                    "type": {
                        "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                        "code": "create"
                    },
                    "resource": "Patient",
                    "sourceId": "us-core-valid",
                    "responseId": "create-response",
                    "encodeRequestUrl": false
                }
            },
            {
                "assert": {
                    "label": "01-ReadPatientOK",
                    "description": "Confirm patient created.",
                    "direction": "response",
                    "resource": "Patient",
                    "warningOnly": false
                }
            },
            {
                "assert": {
                    "label": "Confirm first name is Child",
                    "expression": "Patient.name.given[0]",
                    "value": "Child",
                    "warningOnly": false
                }
            }
        ]
    },
    "test": [
        {
            "id": "Read US Core Patient",
            "name": "Read US Core Patient",
            "description": "Read a US Core Patient and validate response.",
            "action": [
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "read"
                        },
                        "targetId": "create-response",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Patient.id",
                        "operator": "equals",
                        "compareToSourceId": "create-response",
                        "compareToSourceExpression": "Patient.id",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Patient.meta.versionId.empty()",
                        "operator": "equals",
                        "value": "false",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Patient.meta.versionId",
                        "operator": "equals",
                        "compareToSourceId": "create-response",
                        "compareToSourceExpression": "$this.meta.versionId",
                        "warningOnly": false
                    }
                }
            ]
        },
        {
            "id": "Attempt to create invalid US Core Patient",
            "name": "Attempt to create invalid US Core Patient",
            "description": "Attempt to create an invalid US Core Patient and validate response.",
            "action": [
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "create"
                        },
                        "resource": "Patient",
                        "sourceId": "us-core-invalid-race-slice",
                        "responseId": "create-invalid-response",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "OperationOutcome.issue[0].code",
                        "operator": "equals",
                        "compareToSourceId": "create-invalid-response",
                        "compareToSourceExpression": "'required'",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "OperationOutcome.issue[0].location",
                        "operator": "equals",
                        "compareToSourceId": "create-invalid-response",
                        "compareToSourceExpression": "'/extension/0/value'",
                        "warningOnly": false
                    }
                }
            ]
        }
    ],
