{
    "id": "date-lt-gt-prefix-patient",
    "url": "https://haste.health/fhir/TestScript/bundle-date-lt-gt-prefix",
    "title": "Full url checks",
    "name": "Bundle date-lt-gt-prefix tests",
    "status": "active",
    "description": "Validate full url is present on search and hist requests.",
    "resourceType": "TestScript",
    "contained": [
        {
            "id": "patient-chalmers",
            "resourceType": "Patient",
            "deceasedDateTime": "2021-08-01",
            "meta": {
                "tag": [
                    {
                        "code": "date-lt-gt-prefix-test"
                    }
                ]
            },
            "name": [
                {
                    "family": "Chalmers",
                    "given": [
                        "Peter"
                    ]
                }
            ]
        }
    ],
    "fixture": [
        {
            "id": "fixture-patient",
            "resource": {
                "reference": "#patient-chalmers"
            },
            "autocreate": false,
            "autodelete": false
        }
    ],
    "test": [
        {
            "id": "01-date-lt-gt-prefix-checks",
            "name": "Full url check.",
            "action": [
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "create"
                        },
                        "resource": "Patient",
                        "sourceId": "fixture-patient",
                        "responseId": "create-response",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "search"
                        },
                        "resource": "Patient",
                        "params": "death-date=gt2021-07-31&_tag=date-lt-gt-prefix-test",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.count()",
                        "operator": "equals",
                        "value": "1",
                        "warningOnly": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "search"
                        },
                        "resource": "Patient",
                        "params": "death-date=gt2021-08-01&_tag=date-lt-gt-prefix-test",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.count()",
                        "operator": "equals",
                        "value": "0",
                        "warningOnly": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "search"
                        },
                        "resource": "Patient",
                        "params": "death-date=lt2021-08-02&_tag=date-lt-gt-prefix-test",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.count()",
                        "operator": "equals",
                        "value": "1",
                        "warningOnly": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "search"
                        },
                        "resource": "Patient",
                        "params": "death-date=lt2021-08-01&_tag=date-lt-gt-prefix-test",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.count()",
                        "operator": "equals",
                        "value": "0",
                        "warningOnly": false
                    }
                }
            ]
        }
    ],
    "teardown": {
        "action": [
            {
                "operation": {
                    "type": {
                        "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                        "code": "deleteCondMultiple"
                    },
                    "params": "_tag=date-lt-gt-prefix-test",
                    "encodeRequestUrl": false
                }
            }
        ]
    }
