{
    "id": "history-tests",
    "resourceType": "TestScript",
    "url": "https://haste.health/fhir/TestScript/history-tests",
    "title": "History tests",
    "name": "History Test",
    "status": "active",
    "description": "This test script tests the history operation.",
    "contained": [
        {
            "id": "patient1",
            "resourceType": "Patient",
            "meta": {
                "tag": [
                    {
                        "code": "history-test"
                    }
                ]
            }
        }
    ],
    "fixture": [
        {
            "id": "fixture-patient1",
            "resource": {
                "reference": "#patient1"
            },
            "autocreate": false,
            "autodelete": false
        }
    ],
    "variable": [
        {
            "name": "Ver",
            "sourceId": "create-response",
            "expression": "Patient.meta.versionId"
        },
        {
            "name": "PatientCreateLastUpdated",
            "sourceId": "create-response",
            "expression": "Patient.meta.lastUpdated"
        },
        {
            "name": "PatientUpdateLastUpdated",
            "sourceId": "update-response",
            "expression": "Patient.meta.lastUpdated"
        }
    ],
    "test": [
        {
            "id": "01-history",
            "name": "History testing",
            "action": [
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "create"
                        },
                        "resource": "Patient",
                        "sourceId": "fixture-patient1",
                        "responseId": "create-response",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Patient.id",
                        "compareToSourceExpression": "Patient.id",
                        "operator": "notEquals",
                        "compareToSourceId": "fixture-patient1",
                        "warningOnly": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "history"
                        },
                        "resource": "Patient",
                        "targetId": "create-response",
                        "sourceId": "fixture-patient1",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.resource.id",
                        "compareToSourceExpression": "Patient.id",
                        "compareToSourceId": "create-response",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.resource.meta.versionId",
                        "compareToSourceExpression": "Patient.meta.versionId",
                        "compareToSourceId": "create-response",
                        "warningOnly": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "update"
                        },
                        "resource": "Patient",
                        "targetId": "create-response",
                        "sourceId": "fixture-patient1",
                        "responseId": "update-response",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "history"
                        },
                        "resource": "Patient",
                        "targetId": "create-response",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.resource.count()",
                        "operator": "equals",
                        "value": "2",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry[0].resource.id",
                        "compareToSourceExpression": "Patient.id",
                        "compareToSourceId": "update-response",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry[0].resource.meta.versionId",
                        "compareToSourceExpression": "Patient.meta.versionId",
                        "compareToSourceId": "update-response",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry[0].resource.id",
                        "compareToSourceExpression": "Patient.id",
                        "compareToSourceId": "update-response",
                        "operator": "equals",
                        "warningOnly": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "history"
                        },
                        "resource": "Patient",
                        "params": "_since=${PatientUpdateLastUpdated}",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.resource.count()",
                        "operator": "equals",
                        "value": "1",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.resource.id",
                        "compareToSourceExpression": "Patient.id",
                        "compareToSourceId": "update-response",
                        "operator": "equals",
                        "warningOnly": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "history"
                        },
                        "resource": "Patient",
                        "params": "_since=${PatientCreateLastUpdated}",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry.resource.count()",
                        "operator": "equals",
                        "value": "2",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry[1].resource.id",
                        "compareToSourceExpression": "Patient.id",
                        "compareToSourceId": "create-response",
                        "operator": "equals",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Bundle.entry[1].resource.meta.versionId",
                        "compareToSourceExpression": "Patient.meta.versionId",
                        "compareToSourceId": "create-response",
                        "operator": "equals",
                        "warningOnly": false
                    }
                },
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "history"
                        },
                        "resource": "Patient",
                        "params": "_since=asdf",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "resource": "OperationOutcome",
                        "warningOnly": false
                    }
                }
            ]
        }
    ],
    "teardown": {
        "action": [
            {
                "operation": {
                    "type": {
                        "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                        "code": "deleteCondMultiple"
                    },
                    "params": "_tag=history-test",
                    "encodeRequestUrl": false
                }
            }
        ]
    }
}