{
    "id": "read-patient",
    "title": "Read tests",
    "name": "Read Patient",
    "status": "active",
    "url": "https://haste.health/fhir/TestScript/read-patient",
    "description": "Creates a patient and validate read response.",
    "resourceType": "TestScript",
    "contained": [
        {
            "id": "patient-chalmers",
            "resourceType": "Patient",
            "meta": {
                "tag": [
                    {
                        "code": "read-test"
                    }
                ]
            },
            "name": [
                {
                    "family": "Chalmers",
                    "given": [
                        "Peter"
                    ]
                }
            ]
        }
    ],
    "fixture": [
        {
            "id": "fixture-patient-create",
            "resource": {
                "reference": "#patient-chalmers"
            },
            "autocreate": false,
            "autodelete": false
        }
    ],
    "setup": {
        "action": [
            {
                "operation": {
                    "type": {
                        "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                        "code": "create"
                    },
                    "resource": "Patient",
                    "sourceId": "fixture-patient-create",
                    "responseId": "create-response",
                    "encodeRequestUrl": false
                }
            },
            {
                "assert": {
                    "label": "01-ReadPatientOK",
                    "description": "Confirm patient created.",
                    "direction": "response",
                    "resource": "Patient",
                    "warningOnly": false
                }
            },
            {
                "assert": {
                    "label": "Confirm first name is Peter",
                    "expression": "Patient.name.given[0]",
                    "value": "Pete",
                    "warningOnly": false
                }
            }
        ]
    },
    "test": [
        {
            "id": "Read Patient",
            "name": "Read Patient",
            "description": "Read a Patient and validate response.",
            "action": [
                {
                    "operation": {
                        "type": {
                            "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                            "code": "read"
                        },
                        "targetId": "create-response",
                        "encodeRequestUrl": false
                    }
                },
                {
                    "assert": {
                        "expression": "Patient.id",
                        "operator": "equals",
                        "compareToSourceId": "create-response",
                        "compareToSourceExpression": "Patient.id",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Patient.meta.versionId.empty()",
                        "operator": "equals",
                        "value": "false",
                        "warningOnly": false
                    }
                },
                {
                    "assert": {
                        "expression": "Patient.meta.versionId",
                        "operator": "equals",
                        "compareToSourceId": "create-response",
                        "compareToSourceExpression": "$this.meta.versionId",
                        "warningOnly": false
                    }
                }
            ]
        }
    ],
    "teardown": {
        "action": [
            {
                "operation": {
                    "type": {
                        "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
                        "code": "deleteCondMultiple"
                    },
                    "resource": "Patient",
                    "params": "_tag=read-test",
                    "description": "Delete Patients created in test.",
                    "encodeRequestUrl": false
                }
            }
        ]
    }
}